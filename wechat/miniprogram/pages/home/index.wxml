<navigation-bar title="meeting" back="{{false}}" color="white" background="transparent"></navigation-bar>

<view class="page">
  <view class="hero">
    <view class="hero-title">欢迎回来</view>
  </view>

  <view class="card profile-card">
    <view wx:if="{{loading}}" class="loading-text">正在读取账号信息...</view>
    <block wx:else>
      <view class="profile-name">{{nickname}}</view>
      <view class="profile-email">{{email}}</view>
    </block>
  </view>

  <view class="card action-card">
    <view class="card-title">加入会议</view>
    <button class="primary-button" bindtap="handleJoinMeeting">加入会议</button>
  </view>

  <view wx:if="{{recentMeeting}}" class="card recent-card">
    <view class="card-title">最近会议</view>
    <view class="recent-number">{{recentMeeting.meetingNumber}}</view>
    <view class="recent-title">{{recentMeeting.title}}</view>
    <view class="recent-meta">{{recentMeeting.passwordRequired ? '需要会议密码' : '无需会议密码'}}</view>
    <button class="secondary-button" bindtap="handleContinueRecentMeeting">继续加入</button>
  </view>

  <button class="secondary-button logout-button" bindtap="handleLogout">退出登录</button>
</view>
