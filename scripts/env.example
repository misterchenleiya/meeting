# meeting-backend SendCloud API configuration
#
# Copy this file to the deployment root, for example:
#   /data/07c2.com.cn/meeting/meeting-backend.env
# Then fill in the real values and keep that file outside the repository.

MEETING_MAILER_MODE=sendcloud_api
MEETING_SENDCLOUD_API_BASE_URL=https://api.sendcloud.net/apiv2
MEETING_SENDCLOUD_API_USER=replace_with_real_api_user
MEETING_SENDCLOUD_API_KEY=replace_with_real_api_key
MEETING_SENDCLOUD_FROM_ADDRESS=no-reply@mail.07c2.com.cn
MEETING_SENDCLOUD_FROM_NAME=meeting
MEETING_AUTH_CODE_SUBJECT_PREFIX=[meeting]
MEETING_WECHAT_MINIPROGRAM_APP_ID=replace_with_real_wechat_app_id
MEETING_WECHAT_MINIPROGRAM_APP_SECRET=replace_with_real_wechat_app_secret
MEETING_WECHAT_MINIPROGRAM_API_BASE_URL=https://api.weixin.qq.com

# Optional SMTP fallback:
# MEETING_SMTP_HOST=smtp.sendcloud.net
# MEETING_SMTP_PORT=587
# MEETING_SMTP_USERNAME=replace_with_real_username
# MEETING_SMTP_PASSWORD=replace_with_real_password
# MEETING_SMTP_FROM_ADDRESS=no-reply@mail.07c2.com.cn
# MEETING_SMTP_FROM_NAME=meeting
# MEETING_SMTP_REQUIRE_TLS=true
