# meeting-backend SMTP relay configuration
#
# Copy this file to a production-only location such as:
#   /etc/meeting/meeting-backend.env
# Then fill in the real values and keep that file outside the repository.

MEETING_MAILER_MODE=smtp
MEETING_SMTP_HOST=smtp.sendcloud.net
MEETING_SMTP_PORT=587
MEETING_SMTP_USERNAME=replace_with_real_username
MEETING_SMTP_PASSWORD=replace_with_real_password
MEETING_SMTP_FROM_ADDRESS=notice@example.com
MEETING_SMTP_FROM_NAME=meeting
MEETING_SMTP_REQUIRE_TLS=true
MEETING_AUTH_CODE_SUBJECT_PREFIX=[meeting]
